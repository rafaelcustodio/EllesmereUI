package-as: EllesmereUI

move-folders:
  EllesmereUI/EllesmereUIActionBars: EllesmereUIActionBars
  EllesmereUI/EllesmereUIAuraBuffReminders: EllesmereUIAuraBuffReminders
  EllesmereUI/EllesmereUIBags: EllesmereUIBags
  EllesmereUI/EllesmereUIBasics: EllesmereUIBasics
  EllesmereUI/EllesmereUIBlizzardSkin: EllesmereUIBlizzardSkin
  EllesmereUI/EllesmereUIChat: EllesmereUIChat
  EllesmereUI/EllesmereUICooldownManager: EllesmereUICooldownManager
  EllesmereUI/EllesmereUIDamageMeters: EllesmereUIDamageMeters
  EllesmereUI/EllesmereUIDataBars: EllesmereUIDataBars
  EllesmereUI/EllesmereUIFriends: EllesmereUIFriends
  EllesmereUI/EllesmereUIMinimap: EllesmereUIMinimap
  EllesmereUI/EllesmereUIMythicTimer: EllesmereUIMythicTimer
  EllesmereUI/EllesmereUINameplates: EllesmereUINameplates
  EllesmereUI/EllesmereUIQoL: EllesmereUIQoL
  EllesmereUI/EllesmereUIQuestTracker: EllesmereUIQuestTracker
  EllesmereUI/EllesmereUIRaidFrames: EllesmereUIRaidFrames
  EllesmereUI/EllesmereUIResourceBars: EllesmereUIResourceBars
  EllesmereUI/EllesmereUIUnitFrames: EllesmereUIUnitFrames
  EllesmereUI/EllesmereUIAdvancedDebuffs: EllesmereUIAdvancedDebuffs
  EllesmereUI/EllesmereUIPrivateAuras: EllesmereUIPrivateAuras
  EllesmereUI/EllesmereUIRaidControl: EllesmereUIRaidControl
  EllesmereUI/EllesmereUIReminders: EllesmereUIReminders

externals:
  EllesmereUIUnitFrames/Libs/oUF:
    url: https://github.com/oUF-wow/oUF
    tag: latest
  Libs/LibStub:
    url: https://repos.wowace.com/wow/libstub/trunk
    tag: 1.0
  Libs/CallbackHandler-1.0:
    url: https://repos.wowace.com/wow/callbackhandler/trunk/CallbackHandler-1.0
  Libs/LibSharedMedia-3.0:
    url: https://repos.wowace.com/wow/libsharedmedia-3-0/trunk/LibSharedMedia-3.0
  Libs/LibDeflate:
    url: https://github.com/SafeteeWoW/LibDeflate
    tag: latest
  Libs/LibKeystone:
    url: https://github.com/BigWigsMods/LibKeystone.git/LibKeystone

enable-nolib-creation: no

ignore:
  - .github
  - .gitignore
  - .gitattributes
  - .kiro
  - .tools
  - CONTRIBUTING_TRANSLATIONS.md
  - Locales/_keys.txt
  - README.md
  - CHANGELOG.md
